# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/ai_study_planner
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=0

# JWT Configuration
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Ollama AI Service (Local Development)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TEMPERATURE=0.2
OLLAMA_NUM_CTX=4096
OLLAMA_TIMEOUT=30

# AI Service Type: "ollama" (local) or "colab" (production)
AI_SERVICE_TYPE=ollama

# Google Colab Configuration (Production)
# COLAB_API_URL=https://your-ngrok-url.ngrok.io
# COLAB_API_KEY=your-secret-api-key

# LoRA Configuration
LORA_ENABLED=False
LORA_ADAPTER_PATH=./lora-adapters
LORA_DEFAULT_ADAPTER=study-planning-v1

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Application Settings
APP_NAME=AI Study Planner
APP_VERSION=1.0.0
DEBUG=True
LOG_LEVEL=INFO

# Resource Limits
MAX_CONCURRENT_AI_REQUESTS=1
CACHE_MAX_ENTRIES=100
CACHE_TTL_SECONDS=300

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
