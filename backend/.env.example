# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/ai_study_planner
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=0

# JWT Configuration
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Ollama AI Service (Local Development)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TEMPERATURE=0.2
OLLAMA_NUM_CTX=4096
OLLAMA_TIMEOUT=30

# AI Service Type: "ollama" (local) or "colab" (production)
AI_SERVICE_TYPE=ollama

# Google Colab Configuration (Production avec Llama 3.1-8B)
# Décommentez et configurez ces lignes pour utiliser Google Colab:
# 1. Ouvrez notebooks/colab_aiplaning.ipynb dans Google Colab
# 2. Sélectionnez Runtime → Change runtime type → L4 GPU (recommandé) ou A100
# 3. Exécutez toutes les cellules (Runtime → Run all)
# 4. Copiez l'URL ngrok et la clé API affichées
# 5. Décommentez et complétez les lignes ci-dessous
#
# GPU recommandés pour Llama 3.1-8B :
# - L4 (24GB)  : 40-60 tokens/s, excellent compromis qualité/prix
# - A100 (40GB): 80-120 tokens/s, performances maximales
# - T4 (16GB)  : Utilisera automatiquement Llama 3.2-3B (30-40 tokens/s)
#
# COLAB_API_URL=https://xxxx-xx-xx-xx-xx.ngrok-free.app
# COLAB_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LoRA Configuration
LORA_ENABLED=False
LORA_ADAPTER_PATH=./lora-adapters
LORA_DEFAULT_ADAPTER=study-planning-v1

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Application Settings
APP_NAME=AI Study Planner
APP_VERSION=1.0.0
DEBUG=True
LOG_LEVEL=INFO

# Resource Limits
MAX_CONCURRENT_AI_REQUESTS=1
CACHE_MAX_ENTRIES=100
CACHE_TTL_SECONDS=300

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# ──────────────────────────────────────────────
# Email / SMTP — Mot de passe oublié
# ──────────────────────────────────────────────
# Si non configuré, le lien de reset s'affiche uniquement dans les logs backend (mode dev)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=votre-email@gmail.com
# SMTP_PASSWORD=votre-mot-de-passe-application
# SMTP_FROM=noreply@votredomaine.com

# URL du frontend (pour construire le lien de reset dans l'email)
FRONTEND_URL=http://localhost:5173

